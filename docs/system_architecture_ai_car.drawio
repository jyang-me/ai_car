        </mxCell>

        <mxCell id="stm32_lane" value="STM32 小车控制端" style="swimlane;whiteSpace=wrap;html=1;rounded=0;fillColor=#f5f5f5;strokeColor=#666666;fontSize=16;fontStyle=1" vertex="1" parent="1">
