        <mxCell id="n1" value="问题现象&lt;br&gt;手机蓝牙发送后 OLED 无变化" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1" vertex="1" parent="1"><mxGeometry x="410" y="120" width="260" height="80" as="geometry"/></mxCell>
