        <mxCell id="n1" value="用户说出小车指令&lt;br&gt;前进 / 后退 / 左转 / 停止" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1">
