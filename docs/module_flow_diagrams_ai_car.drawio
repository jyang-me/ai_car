        <mxCell id="n2" value="ESP32-S3 小智设备&lt;br&gt;采集音频并通过 WebSocket 上传" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1">
