        <mxCell id="car_controller" value="CarController&lt;br&gt;生成 ASCII 指令&lt;br&gt;F5 / B5 / L5 / R5 / S0" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1" parent="esp32_lane">
