        <mxCell id="n5" value="CarController 归一化速度&lt;br&gt;0-100 或 0-9 -&gt; 档位 0-9" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="80" y="470" width="220" height="85" as="geometry"/>
