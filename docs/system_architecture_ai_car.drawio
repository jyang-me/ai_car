        <mxCell id="debug_lane" value="调试旁路" style="swimlane;whiteSpace=wrap;html=1;rounded=0;fillColor=#f5f5f5;strokeColor=#666666;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="390" y="805" width="670" height="125" as="geometry"/>
        </mxCell>
        <mxCell id="usb_ttl_jdy31" value="USB-TTL 抓 JDY31 输出&lt;br&gt;JDY31 TXD -&gt; USB-TTL RXD&lt;br&gt;验证手机/JDY34 是否真的发出 F5" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13" vertex="1" parent="debug_lane">
          <mxGeometry x="35" y="45" width="280" height="65" as="geometry"/>
        </mxCell>
        <mxCell id="usb_ttl_stm32" value="USB-TTL 直发 STM32&lt;br&gt;USB-TTL TXD -&gt; PA10&lt;br&gt;验证 USART1/OLED 解析正常" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13" vertex="1" parent="debug_lane">
          <mxGeometry x="355" y="45" width="280" height="65" as="geometry"/>
        </mxCell>

        <mxCell id="note" value="当前已验证：JDY31 输出准确；电脑 USB-TTL 直发 PA10 时 OLED 有显示。若手机蓝牙发送无变化，优先检查手机是否真正连接 JDY31 SPP 串口、是否文本发送、JDY31 是否被 JDY34 占用。" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="40" y="805" width="300" height="125" as="geometry"/>
