        <mxCell id="e3" value="选择循迹" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#82b366" edge="1" parent="1" source="mode_select" target="line_task"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="选择蓝牙遥控" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#6c8ebf" edge="1" parent="1" source="mode_select" target="bt_remote"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#82b366" edge="1" parent="1" source="line_input" target="line_task"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#82b366" edge="1" parent="1" source="imu_input" target="line_task"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" style="endArrow=block;html=1;rounded=0;strokeWidth=2;strokeColor=#6c8ebf" edge="1" parent="1" source="phone_bt" target="usart1"><mxGeometry relative="1" as="geometry"/></mxCell>
