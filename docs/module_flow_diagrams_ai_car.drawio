        <mxCell id="n4" value="否：查 STM32 固件&lt;br&gt;USART1 / PA10 / 中断 / OLED" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14" vertex="1" parent="1"><mxGeometry x="700" y="280" width="250" height="95" as="geometry"/></mxCell>
