<mxfile host="app.diagrams.net" modified="2026-06-24T00:00:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="functional-architecture" name="AI Car Functional Architecture">
    <mxGraphModel dx="1500" dy="980" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="940" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title" value="STM32 智能小车功能架构图：循迹 + 蓝牙遥控" style="text;html=1;strokeColor=none;fillColor=none;fontSize=26;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="380" y="30" width="650" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="top_note" value="核心理解：小车主功能分为两条业务线。循迹依赖红外传感器和姿态/角点逻辑；蓝牙遥控依赖 JDY31 串口指令。两条业务线共用菜单、按键、安全停车、OLED、电机驱动和底盘执行层。" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fff4d6;strokeColor=#d6b656;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="90" y="85" width="1220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="ui_layer" value="人机交互与模式选择层" style="swimlane;whiteSpace=wrap;html=1;rounded=0;fillColor=#f5f5f5;strokeColor=#666666;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="90" y="180" width="1220" height="135" as="geometry"/>
        </mxCell>
        <mxCell id="keys" value="按键输入&lt;br&gt;KEY0：切换/启停&lt;br&gt;KEY1：确认/返回" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13" vertex="1" parent="ui_layer">
          <mxGeometry x="55" y="50" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="menu" value="OLED 菜单系统&lt;br&gt;Line Mode / BT Mode&lt;br&gt;选择具体运行模式" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1" parent="ui_layer">
          <mxGeometry x="360" y="45" width="250" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="mode_select" value="运行模式&lt;br&gt;Line CW / Line CCW / Line Target&lt;br&gt;Phone BT / Voice BT" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1" vertex="1" parent="ui_layer">
          <mxGeometry x="715" y="45" width="290" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="line_lane" value="主功能 A：循迹模式" style="swimlane;whiteSpace=wrap;html=1;rounded=0;fillColor=#eef8ed;strokeColor=#82b366;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="90" y="360" width="560" height="330" as="geometry"/>
        </mxCell>
        <mxCell id="line_input" value="输入感知&lt;br&gt;8 路红外循迹传感器&lt;br&gt;黑线状态 / line_err" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14" vertex="1" parent="line_lane">
          <mxGeometry x="45" y="65" width="210" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="imu_input" value="姿态辅助&lt;br&gt;JY61P / USART3&lt;br&gt;yaw 角度" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14" vertex="1" parent="line_lane">
          <mxGeometry x="305" y="65" width="210" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="line_task" value="LINE_TASK 状态机&lt;br&gt;顺/逆时针循迹&lt;br&gt;指定角点计数&lt;br&gt;丢线/转向/完成判断" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1" parent="line_lane">
          <mxGeometry x="165" y="195" width="230" height="105" as="geometry"/>
        </mxCell>

        <mxCell id="bt_lane" value="主功能 B：蓝牙遥控模式" style="swimlane;whiteSpace=wrap;html=1;rounded=0;fillColor=#eef4ff;strokeColor=#6c8ebf;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="750" y="360" width="560" height="330" as="geometry"/>
        </mxCell>
        <mxCell id="phone_bt" value="手机蓝牙串口&lt;br&gt;Phone BT&lt;br&gt;文本 F / F5 / S0" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="bt_lane">
          <mxGeometry x="40" y="60" width="200" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="voice_bt" value="语音蓝牙链路&lt;br&gt;ESP32 - JDY34 - JDY31&lt;br&gt;F5 / B5 / L5 / R5 / S0" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14" vertex="1" parent="bt_lane">
          <mxGeometry x="315" y="60" width="210" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="usart1" value="USART1 接收层&lt;br&gt;JDY31 TXD -&gt; PA10&lt;br&gt;9600 8N1" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14" vertex="1" parent="bt_lane">
          <mxGeometry x="40" y="190" width="200" height="85" as="geometry"/>
        </mxCell>
        <mxCell id="bt_remote" value="BT_REMOTE 解析与遥控状态&lt;br&gt;解析 F/B/L/R/S + 档位&lt;br&gt;维护 Cmd / Raw / left_pwm / right_pwm&lt;br&gt;2 秒无数据停车" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1" parent="bt_lane">
          <mxGeometry x="290" y="180" width="250" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="shared_layer" value="共用控制与执行层" style="swimlane;whiteSpace=wrap;html=1;rounded=0;fillColor=#f5f5f5;strokeColor=#666666;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="90" y="735" width="1220" height="155" as="geometry"/>
        </mxCell>
        <mxCell id="safety" value="安全与启停&lt;br&gt;KEY0 使能电机&lt;br&gt;KEY1 安全返回&lt;br&gt;超时停车" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13" vertex="1" parent="shared_layer">
          <mxGeometry x="55" y="55" width="220" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="pwm_compute" value="运动控制输出&lt;br&gt;循迹修正 / 遥控指令&lt;br&gt;统一得到 left_pwm / right_pwm" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1" vertex="1" parent="shared_layer">
          <mxGeometry x="360" y="50" width="250" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="motor" value="底盘执行&lt;br&gt;TIM3 PWM + 方向 GPIO&lt;br&gt;左/右电机" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1" vertex="1" parent="shared_layer">
          <mxGeometry x="705" y="50" width="220" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="oled_status" value="状态显示&lt;br&gt;模式 / Cmd / Raw&lt;br&gt;Left / Right / 循迹状态" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13" vertex="1" parent="shared_layer">
          <mxGeometry x="995" y="50" width="190" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="e1" style="endArrow=block;html=1;rounded=0;strokeWidth=2" edge="1" parent="1" source="keys" target="menu"><mxGeometry relative="1" as="geometry"/></mxCell>
