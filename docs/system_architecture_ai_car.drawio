          <mxGeometry x="55" y="280" width="190" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="jdy31" value="JDY31&lt;br&gt;BLE 从机&lt;br&gt;TXD 输出到 STM32" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1" parent="ble_lane">
