          <mxGeometry x="55" y="335" width="230" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="motor" value="电机控制&lt;br&gt;TIM3 PWM + 方向 GPIO&lt;br&gt;左/右电机速度状态" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1" vertex="1" parent="stm32_lane">
